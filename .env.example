SECRET_KEY=your-secret-key-here
DEBUG=True
DB_NAME=deeni_jobs
DB_USER=postgres
DB_PASSWORD=your-password-here
DB_HOST=localhost
DB_PORT=5432
# DATABASE_URL=postgresql://user:password@host:port/dbname  # Railway Postgres (overrides DB_* when set)
ALLOWED_HOSTS=localhost,127.0.0.1,islamicjobz.com,www.islamicjobz.com

# Media storage — leave USE_R2_STORAGE=False for local filesystem (default)
USE_R2_STORAGE=False
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=your-bucket-name
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-your-bucket-id.r2.dev

# Email - leave USE_REAL_EMAIL=False locally to print emails to the console.
USE_REAL_EMAIL=False
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=your-resend-api-key
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@islamicjobz.com
